{
  "name": "nunchuk-cli",
  "version": "0.1.2",
  "description": "CLI for AI agents to use Bitcoin safely with group and miniscript wallets",
  "license": "MIT",
  "type": "module",
  "repository": "github:nunchuk-io/nunchuk-cli",
  "homepage": "https://github.com/nunchuk-io/nunchuk-cli",
  "bugs": "https://github.com/nunchuk-io/nunchuk-cli/issues",
  "keywords": [
    "bitcoin",
    "nunchuk",
    "multisig",
    "wallet",
    "nunchuk-cli",
    "cli",
    "miniscript",
    "group-wallet",
    "ai-agent"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "nunchuk": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@scure/bip32": "2.0.1",
    "@scure/bip39": "2.0.1",
    "@scure/btc-signer": "2.0.1",
    "better-sqlite3": "^12.8.0",
    "commander": "12.1.0",
    "tweetnacl": "1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.1"
  }
}
